# 環境変数テンプレート
# このファイルをコピーして .env を作成し、値を設定してください。
# .env はバージョン管理に含めないでください（.gitignore に追加済み）。

# ── MongoDB ──
MONGO_USERNAME=admin
MONGO_PASSWORD=password
MONGO_DB=pioyan_chat
MONGO_URL=mongodb://admin:password@localhost:27017/pioyan_chat?authSource=admin

# ── JWT ──
# 本番環境では必ず長くランダムな文字列に変更してください。
# 生成例: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── FastAPI ──
BACKEND_PORT=8000
CORS_ORIGINS=["http://localhost:3000"]

# ── Next.js ──
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SOCKET_URL=http://localhost:8000

# ── ファイルアップロード ──
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# ── ボットコンテナファイル ──
CONTAINER_FILES_DIR=container_files
MAX_CONTAINER_FILE_SIZE_KB=256
